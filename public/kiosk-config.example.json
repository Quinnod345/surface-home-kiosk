{
  "deviceName": "surface-pro-3-kiosk",
  "debug": false,
  "homeAssistant": {
    "baseUrl": "http://homeassistant.local:8123",
    "dashboardUrl": "http://homeassistant.local:8123/lovelace/default_view?kiosk",
    "accessToken": "",
    "eventPrefix": "surface_kiosk",
    "activePersonEntityId": "input_text.surface_kiosk_active_person"
  },
  "slideshow": {
    "photos": [
      "/photos/family-01.jpg",
      "/photos/family-02.jpg",
      "/photos/family-03.jpg"
    ],
    "intervalMs": 12000
  },
  "camera": {
    "enabled": true,
    "width": 640,
    "height": 480,
    "motionSensitivity": 0.075,
    "motionHoldMs": 9000,
    "closeFaceRatio": 0.34
  },
  "faceRecognition": {
    "enabled": true,
    "modelUrl": "/models",
    "matchThreshold": 0.5,
    "scanIntervalMs": 1400,
    "openDashboardOnRecognition": true,
    "greetCooldownMs": 180000
  },
  "nativeBridge": {
    "enabled": false,
    "url": "ws://127.0.0.1:8765/events",
    "preferredSourceKind": "Infrared"
  },
  "behavior": {
    "dashboardIdleTimeoutMs": 90000,
    "returnToPhotosOnIdle": true,
    "openDashboardOnCloseFace": true,
    "openDashboardOnTap": true
  },
  "people": [
    {
      "id": "quinn",
      "displayName": "Quinn",
      "dashboardPath": "/lovelace/quinn?kiosk",
      "greeting": "Welcome, Quinn.",
      "referenceImageUrls": ["/people/quinn-01.jpg", "/people/quinn-02.jpg"],
      "faceDescriptors": []
    }
  ]
}
